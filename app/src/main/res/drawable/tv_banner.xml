<?xml version="1.0" encoding="utf-8"?>
<!-- TV launcher banner — 320×180 dp, dark gradient with purple accent -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Background gradient -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="#0D0D14"
                android:endColor="#1E1235" />
        </shape>
    </item>
    <!-- Purple accent stripe at the bottom -->
    <item android:top="165dp">
        <shape android:shape="rectangle">
            <solid android:color="#9C7BFF" />
        </shape>
    </item>
    <!-- Coloured LED dots representing the strip -->
    <item android:left="32dp" android:top="72dp" android:right="224dp" android:bottom="72dp">
        <shape android:shape="oval"><solid android:color="#FF4444" /></shape>
    </item>
    <item android:left="72dp" android:top="72dp" android:right="184dp" android:bottom="72dp">
        <shape android:shape="oval"><solid android:color="#FF9900" /></shape>
    </item>
    <item android:left="112dp" android:top="72dp" android:right="144dp" android:bottom="72dp">
        <shape android:shape="oval"><solid android:color="#44FF88" /></shape>
    </item>
    <item android:left="152dp" android:top="72dp" android:right="104dp" android:bottom="72dp">
        <shape android:shape="oval"><solid android:color="#44AAFF" /></shape>
    </item>
    <item android:left="192dp" android:top="72dp" android:right="64dp" android:bottom="72dp">
        <shape android:shape="oval"><solid android:color="#9C7BFF" /></shape>
    </item>
    <item android:left="232dp" android:top="72dp" android:right="24dp" android:bottom="72dp">
        <shape android:shape="oval"><solid android:color="#FF44CC" /></shape>
    </item>
</layer-list>
